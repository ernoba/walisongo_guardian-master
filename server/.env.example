# Walisongo Guardian Server v3.1
# Configuration file - Copy to .env and adjust values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server bind address dan port
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Upload configuration
UPLOAD_ROOT_PATH=./uploads
UPDATE_ROOT_PATH=./updates

# Maximum upload size dalam bytes (50MB)
MAX_UPLOAD_SIZE=52428800

# ============================================================================
# SECURITY
# ============================================================================

# Static encryption key (harus sama dengan client)
STATIC_ENCRYPTION_KEY=WALISONGO_JAYA_SELAMANYA

# API authentication key
API_AUTH_KEY=ADMIN-2025

# ============================================================================
# UPDATE CONFIGURATION
# ============================================================================

# Executable name untuk update check
UPDATE_EXE_NAME=WinSysHelper.exe

# Versi terbaru aplikasi
CURRENT_VERSION=1.6.3

# ============================================================================
# LOGGING
# ============================================================================

# Log level: TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Enable JSON logging untuk integration dengan log aggregation
LOG_JSON=false

# ============================================================================
# DATABASE (Future use)
# ============================================================================

# DATABASE_URL=sqlite:./data/walisongo.db
# DATABASE_POOL_SIZE=10

# ============================================================================
# ADVANCED FEATURES (Optional)
# ============================================================================

# Enable rate limiting
RATE_LIMITING_ENABLED=false
RATE_LIMIT_REQUESTS_PER_SECOND=100

# Enable advanced AES encryption
ADVANCED_ENCRYPTION_ENABLED=false

# Enable database storage
DATABASE_ENABLED=false
